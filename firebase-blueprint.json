{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "chips": { "type": "number" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "chips"]
    },
    "Room": {
      "title": "Room",
      "description": "A poker game room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing"] },
        "smallBlind": { "type": "number" },
        "bigBlind": { "type": "number" },
        "maxPlayers": { "type": "number" },
        "players": { 
          "type": "object",
          "description": "Map of userId to player state at the table"
        },
        "gameState": {
          "type": "object",
          "description": "The full game state (stages, pot, community cards, etc)"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "creatorId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User database"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Active game rooms"
    }
  }
}
