rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.chips > 0;
      
      function isValidUser(data) {
        return data.uid is string && 
               data.name is string && data.name.size() <= 32 &&
               data.chips is number &&
               (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 512));
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().chips <= 10000;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'chips', 'xp', 'level', 'updatedAt'])
      );
    }

    // --- ROOMS ---
    match /rooms/{roomId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      function isValidRoom(data) {
        return data.id is string &&
               data.name is string && data.name.size() <= 64 &&
               data.creatorId is string &&
               data.status in ['waiting', 'playing', 'finished'] &&
               data.smallBlind is number && data.smallBlind >= 0 &&
               data.bigBlind is number && data.bigBlind >= 0 &&
               data.maxPlayers is number && data.maxPlayers >= 2 && data.maxPlayers <= 10;
      }

      allow create: if isSignedIn() && isValidId(roomId) && isValidRoom(incoming()) && incoming().creatorId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        // Action: Join/Leave Room
        (incoming().diff(existing()).affectedKeys().hasOnly(['players', 'updatedAt'])) ||
        // Action: Start Game (Creator only)
        (existing().creatorId == request.auth.uid && incoming().status == 'playing' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'gameState', 'updatedAt'])) ||
        // Action: Player Action (In progress game)
        (existing().status == 'playing' && incoming().diff(existing()).affectedKeys().hasOnly(['gameState', 'status', 'updatedAt']))
      );
    }
  }
}
